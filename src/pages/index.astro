---
import { getCollection } from "astro:content";
import MainLayout from "@/layouts/MainLayout.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<MainLayout isHome={true}>
  <section id="hero" class="pb-6 border-b border-border">
    <div class="flex items-center gap-4">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-6 sm:text-5xl">
        Liahの日記
      </h1>
      <a target="_blank" href="/rss.xml" class="inline-block transition-transform hover:scale-110" aria-label="rss feed" title="RSS Feed">
        <IconRss width={24} height={24} class="stroke-accent stroke-3" />
        <span class="sr-only">RSS Feed</span>
      </a>
    </div>

    <div class="mt-4">
      <h2 class="text-xl font-bold mb-3 border-l-4 border-accent pl-3">ブログ紹介</h2>
      <p class="leading-relaxed opacity-90">
        大学での物理や数学の学習ノートや、高校の復習、
        趣味のゲームの攻略やプログラミングなどをまとめているブログです。<br />
        学習内容の備忘録や、作成したツールの紹介をメインに更新しています。
      </p>
    </div>

    {
      SOCIALS.length > 0 && (
        <div class="mt-6 flex max-sm:flex-col sm:items-center">
          <div class="me-2 mb-1 text-sm font-semibold opacity-80 sm:mb-0">Find me on:</div>
          <Socials />
        </div>
      )
    }
  </section>

  {
    featuredPosts.length > 0 && (
      <section id="recommended" class="pt-10 pb-6 border-b border-border">
        <h2 class="text-2xl font-bold tracking-wide mb-6 border-l-4 border-accent pl-3">おすすめ記事</h2>
        <ul>
          {featuredPosts.map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      </section>
    )
  }

  {
    recentPosts.length > 0 && (
      <section id="recent-posts" class="pt-10 pb-6">
        <h2 class="text-2xl font-bold tracking-wide mb-6 border-l-4 border-accent pl-3">新着記事</h2>
        <ul>
          {recentPosts.map(
            (data, index) =>
              index < SITE.postPerIndex && <Card variant="h3" {...data} />
          )}
        </ul>
      </section>
    )
  }

  <div class="my-8 text-center">
    <LinkButton href="/posts/">
      すべての記事を見る
      <IconArrowRight class="inline-block min-w-5" />
    </LinkButton>
  </div>
</MainLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", "/");
  });
</script>
