---
import { SITE } from "@/config";
import Breadcrumbs from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
import ProfileCard from "@/components/ProfileCard.astro";
import Word from "@/components/Word.astro";
---

<Layout title={`Profile | ${SITE.title}`}>
  <Header />
  <Breadcrumbs />

  <main id="main-content" class="app-layout mt-8 pb-12">
    <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-[320px_1fr]">
      <aside class="flex w-full flex-col gap-6">
        <ProfileCard />
      </aside>

      <div
        class="app-prose w-full min-w-0 rounded-xl border border-border bg-background p-6 shadow-sm md:p-8"
      >
        <h1 class="mb-6 text-2xl font-bold text-accent sm:text-3xl">
          Liahについて
        </h1>

        <ul class="mb-8 list-none pl-0">
          <li>・工学部の情報工学科に通う大学2年生</li>
          <li>
            ・普段はゲームに没頭したり、ラノベを読み耽ったりしている、根っからのインドア派
          </li>
          <li>
            ・大学の長期休みがあまりにも長すぎて、さすがにゲームをし続けるのに罪悪感を感じ、ブログを自作し、塾講師のバイトを始めてみた
          </li>
        </ul>

        <h2 class="mb-4 border-b border-border pb-2 text-xl font-bold">
          書くことが思いつかないので、いったん省略します。
        </h2>
        <p>眠いです...</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
