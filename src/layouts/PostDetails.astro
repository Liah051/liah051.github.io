---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import DefaultSidebar from "@/components/sidebars/DefaultSidebar.astro";
import BlueProtocolSidebar from "@/components/sidebars/BlueProtocol.astro";
import Comments from "@/components/Comments.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import PhysicsSidebar from "@/components/sidebars/PhysicsSidebar.astro";
import Word from "@/components/Word.astro";
import PostFooterStack from "@/components/PostFooterStack.astro";


// ... [既存のインポートを維持、手動でマージするのではなくインポート部分全体を編集すると長くなるので、最初の方に追加します]
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  category_id,
} = post.data;

const { Content, headings } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};
---

<Layout {...layoutProps}>
  <Header category_id={category_id} isPost={true} headings={headings} />
  <BackButton backUrl={category_id && category_id !== "other" ? `/${category_id}` : undefined} backText={category_id && category_id !== "other" ? "< トップに戻る" : undefined} />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <!-- 
      - justify-between と gap-x を併用してサイドバーを右端に可能な限り押し出し、「プロフィール」メニュー右側配置へ誘導
      - メインコンテンツは明確な最大幅を指定し、右端が「タグ」中央に来るよう制限
      - -ml-[1em] 等で全角1文字分ほどの左寄りシフトを実現
    -->
    <div class="flex flex-col md:flex-row md:justify-between items-start md:items-stretch gap-18 lg:gap-24">
      <!-- Left Column: Main Content -->
      <div class="w-full min-w-0 md:max-w-[780px] lg:max-w-[800px] md:translate-x-0">

        <h1
          transition:name={slugifyStr(title.replaceAll(".", "-"))}
          class="inline-block text-2xl font-bold text-accent sm:text-3xl"
        >
          {title}
        </h1>
        <div class="my-2 flex items-center gap-2">
          <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} timezone={timezone} size="lg" />

          <span
            aria-hidden="true"
            class:list={[
              "max-sm:hidden",
              { hidden: !SITE.editPost.enabled || hideEditPost },
            ]}>|</span
          >
          <EditPost hideEditPost={hideEditPost} post={post} class="max-sm:hidden" />

        </div>

        <div class="mt-8">
          <TableOfContents headings={headings} mode="collapsible" />
        </div>

        <article
          id="article"
          class="app-prose w-full prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
        >
          <Content components={{ Word }} />

        </article>

        <hr class="my-8 border-dashed" />

        <EditPost class="sm:hidden" hideEditPost={hideEditPost} post={post} />



        <PostFooterStack post={post} posts={posts} />

        <ul class="mt-8 mb-8 flex flex-wrap gap-4 sm:my-8">
          {
            tags.map(tag => (
              <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
            ))
          }
        </ul>

        <BackToTopButton />

        <ShareLinks />

        <hr class="my-6 border-dashed" />

        <Comments id={post.id} title={title} url={Astro.url.href} />

      </div>

      <!-- Right Column: Sidebar -->
      <aside
        class="hidden md:flex w-full flex-col gap-6 pb-8 md:order-last md:pb-0 md:w-[252px] lg:w-[270px] shrink-0"

      >
        {
          category_id === "blue-protocol" ? (
            <BlueProtocolSidebar />
          ) : category_id === "physics" ? (
            <PhysicsSidebar />
          ) : (
            <DefaultSidebar />
          )
        }

        <!-- Table of Contents -->
        <TableOfContents headings={headings} mode="sticky" />
      </aside>
    </div>

  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator at the top */
  function setupProgressBar() {
    // Check if progress bar already exists to avoid duplicates
    if (document.querySelector(".progress-container")) return;

    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-[60] h-1 w-full bg-background";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
    
    // Use a single listener for scroll updates
    window.addEventListener("scroll", () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      const myBar = document.getElementById("myBar");
      if (myBar) {
        myBar.style.width = scrolled + "%";
      }
    }, { passive: true });
  }

  /** Attaches links to headings */
  function addHeadingLinks() {
    const headings = document.querySelectorAll("h2[id], h3[id], h4[id], h5[id], h6[id]");
    for (const heading of headings) {
      if (heading.querySelector(".heading-link")) continue;
      
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }

  /** Copy buttons for code blocks */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      if (codeBlock.querySelector(".copy-code")) continue;

      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      const topClass = hasFileNameOffset ? "top-(--file-name-offset)" : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium transition-all hover:bg-muted/80`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      if (codeBlock.parentNode) {
        codeBlock.parentNode.insertBefore(wrapper, codeBlock);
        wrapper.appendChild(codeBlock);
      }

      copyButton.addEventListener("click", async () => {
        const code = codeBlock.querySelector("code");
        const text = code?.innerText || "";
        try {
          await navigator.clipboard.writeText(text);
          copyButton.innerText = "Copied";
          setTimeout(() => { copyButton.innerText = copyButtonLabel; }, 700);
        } catch (err) {
          console.error("Failed to copy:", err);
        }
      });
    }
  }

  // Initialize features
  setupProgressBar();
  addHeadingLinks();
  attachCopyButtons();

  // Handle scroll reset after transition
  document.addEventListener("astro:after-swap", () => {
    window.scrollTo({ left: 0, top: 0, behavior: "instant" });
  }, { once: true });
</script>
