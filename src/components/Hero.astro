---
---

<section 
  class="relative w-full overflow-hidden rounded-3xl bg-slate-950 border border-slate-800 shadow-2xl p-8 sm:p-12 mb-8 group"
>
  <!-- Background Decor: Grid -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff0a_1px,transparent_1px),linear-gradient(to_bottom,#ffffff0a_1px,transparent_1px)] bg-[size:24px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>

  <!-- Background Decor: Glow effects -->
  <div class="absolute -top-32 -right-32 w-[32rem] h-[32rem] bg-[var(--color-accent)]/15 rounded-full blur-3xl opacity-50 mix-blend-screen transition-transform duration-1000 group-hover:scale-110"></div>
  <div class="absolute -bottom-32 -left-32 w-[24rem] h-[24rem] bg-blue-500/15 rounded-full blur-3xl opacity-40 mix-blend-screen transition-transform duration-1000 group-hover:scale-110"></div>

  <div class="relative z-10 flex flex-col items-center text-center">
    <!-- Header row with Name -->
    <h1 class="text-6xl sm:text-8xl font-black tracking-tighter bg-clip-text text-transparent bg-gradient-to-br from-white via-slate-200 to-slate-500 drop-shadow-[0_2px_10px_rgba(255,255,255,0.1)] mb-4 select-none">
      Liah
    </h1>

    <!-- Badge / Subtitle -->
    <div class="mb-6 inline-flex items-center rounded-full border border-slate-700/60 bg-slate-800/40 px-3 py-1 text-sm font-medium text-slate-300 backdrop-blur-sm cursor-default">
      <span class="flex h-2 w-2 rounded-full bg-emerald-500 mr-2 animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.8)]"></span>
      Engineering Student & Developer
    </div>

    <!-- Description -->
    <p class="text-base sm:text-lg text-slate-400 max-w-xl leading-relaxed font-medium">
      情報系学生の技術ブログ兼ポートフォリオ。<br class="hidden sm:block" />
      <span class="text-slate-200 font-semibold drop-shadow-[0_0_8px_rgba(255,255,255,0.3)]">C言語</span>や<span class="text-slate-200 font-semibold drop-shadow-[0_0_8px_rgba(255,255,255,0.3)]">JavaScript</span>を中心に、技術の探求と日々の学びを記録しています。
    </p>

    <!-- Call to Actions -->
    <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
      <a href="/posts" class="group/btn relative w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 text-sm font-bold text-slate-950 transition-all duration-300 bg-slate-100 rounded-xl overflow-hidden shadow-lg hover:bg-white hover:shadow-[0_0_20px_rgba(255,255,255,0.6)] hover:-translate-y-0.5">
        <span class="relative z-10 flex items-center gap-2">
          Read Articles
          <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </span>
      </a>

      <a href="https://github.com/liah051" target="_blank" rel="noopener noreferrer" class="group/btn2 relative w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 text-sm font-bold text-slate-200 transition-all duration-300 bg-slate-800/80 border border-slate-700 rounded-xl overflow-hidden shadow-lg hover:bg-slate-700 hover:text-white hover:border-slate-500 hover:shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:-translate-y-0.5 backdrop-blur-sm">
        <svg class="w-5 h-5 mr-2 opacity-80 group-hover/btn2:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</section>
