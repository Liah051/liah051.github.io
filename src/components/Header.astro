---
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import { SITE } from "@/config";
import MobileDrawer from "./MobileDrawer.astro";
import SearchModal from "./SearchModal.astro";
import type { MarkdownHeading } from "astro";
import GlossaryToggle from "./GlossaryToggle.astro";

export interface Props {
  category_id?: string;
  isPost?: boolean;
  headings?: MarkdownHeading[];
}

const { category_id, isPost, headings } = Astro.props;

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute inset-s-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="sticky top-0 z-40 w-full bg-background/95 backdrop-blur-sm border-b border-border">
  <div class="app-layout flex items-center justify-between py-2 sm:py-3">
    
    <!-- 左側：サイトタイトル -->
    <a href="/" class="text-xl font-bold whitespace-nowrap sm:text-2xl hover:text-accent transition-colors">
      {SITE.title}
    </a>

    <!-- 右側：ナビゲーション・アイコン群 -->
    <div class="flex items-center gap-2 sm:gap-6">
      
      <!-- PC版メニュー (sm以上で表示) -->
      <nav class="hidden sm:flex items-center gap-6 text-[1.1rem] font-medium">
        <a href="/posts" class={`hover:text-accent transition-colors ${isActive("/posts") ? "active-nav text-accent" : ""}`}>
          記事一覧
        </a>
        <a href="/tags" class={`hover:text-accent transition-colors ${isActive("/tags") ? "active-nav text-accent" : ""}`}>
          タグ
        </a>
      </nav>

      <div class="flex items-center gap-1 sm:gap-2">
        {SITE.showArchives && (
          <div class="header-tooltip-container relative group">
            <a href="/archives" class={`p-2 hover:text-accent transition-colors flex items-center ${isActive("/archives") ? "active-nav text-accent" : ""}`} aria-label="Archives">
              <IconArchive class="w-6 h-6 stroke-current" />
            </a>
            <span class="header-tooltip">
              アーカイブ
              <span class="tooltip-arrow" />
            </span>
          </div>
        )}
        <GlossaryToggle />

        <!-- 共通アイコン：検索ボタン (クリックでSearchModalを開く) -->
        <div class="header-tooltip-container relative group">
          <button id="search-btn" class="p-2 hover:text-accent transition-colors" aria-label="Search">
            <IconSearch class="w-6 h-6 stroke-current" />
          </button>
          <span class="header-tooltip">
            検索
            <span class="tooltip-arrow" />
          </span>
        </div>

        <!-- 共通アイコン：ダークモード切替 -->
        {SITE.lightAndDarkMode && (
          <div class="header-tooltip-container relative group">
            <button id="theme-btn" class="relative p-2 w-10 h-10 hover:text-accent transition-colors" aria-label="Toggle Theme">
              <IconMoon class="absolute inset-0 m-auto scale-100 dark:scale-0 transition-transform duration-200" />
              <IconSunHigh class="absolute inset-0 m-auto scale-0 dark:scale-100 transition-transform duration-200" />
            </button>
            <span id="theme-tooltip" class="header-tooltip">
              ダークモードに切り替え
              <span class="tooltip-arrow" />
            </span>
          </div>
        )}

        <!-- モバイル版ハンバーガーメニュー (sm未満で表示) -->
        <!-- クリックでMobileDrawerを開く -->
        <button id="menu-btn" class="sm:hidden p-2 hover:text-accent transition-colors" aria-label="Menu">
          <IconMenuDeep class="w-7 h-7 stroke-current" />
        </button>
      </div>

    </div>
  </div>
</header>

<!-- モバイル表示時のドロワーコンポーネント -->
<MobileDrawer category_id={category_id} isPost={isPost} headings={headings} />

<!-- 検索用のオーバーレイモーダル -->
<SearchModal />

<script>
  function updateThemeTooltip() {
    const themeBtn = document.querySelector("#theme-btn");
    const themeTooltip = document.querySelector("#theme-tooltip");
    if (!themeBtn || !themeTooltip) return;

    const tooltipText = themeTooltip.childNodes[0];
    
    // 現在のテーマを確認してテキストを更新
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark";
      if (tooltipText) {
        tooltipText.textContent = isDark ? "ライトモードに切り替え" : "ダークモードに切り替え";
      }
    });

    observer.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
    
    // 初期化
    const isDark = document.documentElement.getAttribute("data-theme") === "dark";
    if (tooltipText) {
      tooltipText.textContent = isDark ? "ライトモードに切り替え" : "ダークモードに切り替え";
    }
  }

  document.addEventListener("astro:page-load", updateThemeTooltip);
</script>

<style>
  .header-tooltip-container {
    display: flex;
    align-items: center;
  }

  /* Word.astro のデザインを継承 */
  .header-tooltip {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 0.5rem;
    padding: 0.25rem 0.5rem;
    background-color: #000000;
    color: #ffffff;
    font-size: 0.75rem;
    white-space: nowrap;
    border-radius: 0.375rem;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    z-index: 50;
    
    /* アニメーション設定 */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.1s, visibility 0.1s;
  }

  .header-tooltip-container:hover .header-tooltip {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  :global(html[data-theme="dark"]) .header-tooltip {
    background-color: #ffffff;
    color: #000000;
  }
</style>
