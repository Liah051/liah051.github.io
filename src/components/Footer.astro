---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="py-6 sm:py-8 border-t border-border flex flex-col items-center">
    
    <!-- Navigation Links -->
    <nav class="mb-6 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm font-medium opacity-90">
      <a href="/" class="hover:text-accent hover:underline">ホーム</a>
      <a href="/privacy" class="hover:text-accent hover:underline">プライバシーポリシー</a>
      <a href="/contact" class="hover:text-accent hover:underline">お問い合わせ</a>
    </nav>
    
    <div class="flex flex-col items-center gap-4 w-full">
      <Socials />
      <div class="flex flex-col items-center whitespace-nowrap">
        <span class="opacity-80">&#169; {currentYear} Liahの日記</span>
      </div>
    </div>
  </div>
</footer>
