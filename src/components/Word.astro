---
import { getGlossary } from "@/utils/glossary";
import SmartImage from "./SmartImage.astro";
import GlossaryDescription from "./GlossaryDescription.astro";

export interface Props {
  id?: string;
}

const { id } = Astro.props;
const termFromSlot = await Astro.slots.render("default");
const glossaryEntries = await getGlossary();

const entry = id
  ? glossaryEntries.find((e) => e.id === id)
  : glossaryEntries.find((e) => e.data.term === termFromSlot.trim());

const { description, url, image } = entry?.data || {};
const displayTitle = entry?.data.term || termFromSlot;
---

{
  entry ? (
    <span class="glossary-word-container relative inline group cursor-help transition-all duration-300">
      <span class="glossary-word transition-colors group-hover:text-accent">
        <slot />
      </span>
      {/* ツールチップコンテナ：影を一体化するために filter: drop-shadow を使用 */}
      <span class="glossary-tooltip absolute bottom-full mb-3 z-50 pointer-events-none group-hover:pointer-events-auto opacity-0 transition-opacity duration-300 overflow-visible">
        <span class="glossary-tooltip-box inline-block w-max max-w-[280px] p-3 text-card-foreground text-sm rounded-lg border border-border relative z-10 shadow-none overflow-hidden">
          <span class="block font-bold mb-2">{displayTitle}</span>
          <span class="flex gap-3 items-center" style="display: flex;">
            {
              image && (
                <SmartImage 
                  image={image} 
                  alt={displayTitle} 
                  class={typeof image === 'object' && 'type' in image && image.type === 'chip' 
                    ? "shrink-0" 
                    : "shrink-0 w-16 h-16 object-cover rounded-md border border-border bg-muted overflow-hidden"} 
                  size={64} 
                />
              )
            }
            <span class="flex-1 min-w-0">
              <span class="block mb-2 text-muted-foreground leading-relaxed"><GlossaryDescription text={description || ""} /></span>
              {
                url && url.length > 0 && (
                  <a href={url} class="text-accent hover:underline flex items-center gap-1 font-medium">
                    詳しく見る →
                  </a>
                )
              }
            </span>
          </span>
        </span>
      </span>
    </span>
  ) : (
    <slot />
  )
}

<script is:inline data-astro-rerun>
  (() => {
    // 既に初期化済みの場合はスキップ（イベントリスナーの重複防止）
    if (window.glossaryPositioningInitialized) return;
    window.glossaryPositioningInitialized = true;

    const adjustTooltip = (container) => {
      const tooltip = container.querySelector('.glossary-tooltip');
      if (!tooltip) return;

      // 1. まず中央揃えのデフォルト状態にする
      tooltip.style.transform = 'translateX(-50%)';

      // 2. レイアウトを確定させて位置を計測
      void tooltip.offsetWidth; 
      const rect = tooltip.getBoundingClientRect();
      const viewportWidth = window.innerWidth;
      const margin = 12;

      // 3. はみ出し判定
      let shift = 0;
      if (rect.left < margin) {
        shift = margin - rect.left;
      } else if (rect.right > viewportWidth - margin) {
        shift = (viewportWidth - margin) - rect.right;
      }

      // 4. 必要に応じて補正適用
      if (shift !== 0) {
        // メインボックスをシフト
        tooltip.style.transform = `translateX(calc(-50% + ${shift}px))`;
      }
    };

    // デリゲートされたイベントリスナーで効率的かつ確実に処理
    document.addEventListener('mouseover', (e) => {
      const container = e.target.closest('.glossary-word-container');
      if (container) {
        adjustTooltip(container);
      }
    });

    // タッチデバイス対応
    document.addEventListener('touchstart', (e) => {
      const container = e.target.closest('.glossary-word-container');
      if (container) {
        adjustTooltip(container);
      }
    }, { passive: true });
  })();
</script>

<style>
  .glossary-word {
    /* カスタムドット下線 */
    background-image: radial-gradient(circle, currentColor 1px, transparent 1px);
    background-position: bottom;
    background-size: 6px 1px;
    background-repeat: repeat-x;
    padding-bottom: 2px;
  }

  /* ツールチップの不透明度とフィルタ */
.glossary-tooltip {
  filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.1));
  /* デフォルトでセンターに配置 */
  left: 50%;
  transform: translateX(-50%); 
  
  /* transformをtransitionに入れないことで「スライド」を防止 */
  transition: opacity 0.3s, visibility 0.3s; 
  transition-delay: 0.3s;
  visibility: hidden;
}

  .glossary-tooltip-box {
    background-color: var(--background); /* 完全に不透明なテーマ背景を使用 */
    opacity: 1 !important;
  }

  /* ダークモードの影 */
  :global(html[data-theme="dark"]) .glossary-tooltip {
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.4));
  }

  /* ホバー時の表示（visibilityを制御してJS의計算を可能にする） */
  .glossary-word-container:hover .glossary-tooltip {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.2s;
    transition-delay: 0s;
    /* absoluteな位置関係を維持 */
    position: absolute;
    bottom: 100%;
    left: 50%;
  }

  /* ツールチップへの架け橋 */
  .glossary-word-container::after {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 50%;
    width: 100%;
    height: 24px;
    transform: translateX(-50%);
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.3s, visibility 0.3s;
    transition-delay: 0.3s;
    background-color: transparent;
    z-index: 40;
  }
  
  .glossary-word-container:hover {
    z-index: 60;
  }

  .glossary-word-container:hover::after {
    visibility: visible;
    opacity: 1;
    transition: none;
  }

  :global(html[data-glossary-hidden="true"]) .glossary-word {
    background-image: none !important;
  }
  
  :global(html[data-glossary-hidden="true"]) .glossary-tooltip,
  :global(html[data-glossary-hidden="true"]) .glossary-word-container::after {
    display: none !important;
  }

  :global(html[data-glossary-hidden="true"]) .glossary-word-container {
    cursor: default !important;
  }
</style>
