---
import { getGlossary } from "@/utils/glossary";

const termFromSlot = await Astro.slots.render("default");
const glossaryEntries = await getGlossary();
const entry = glossaryEntries.find((e) => e.data.term === termFromSlot.trim());

const { description, url } = entry?.data || {};
---

{
  entry ? (
    <span class="glossary-word-container relative inline-block group cursor-help transition-all duration-300">
      <span class="glossary-word transition-colors group-hover:text-accent">
        <slot />
      </span>
      <span class="glossary-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-max max-w-[250px] p-3 bg-card text-card-foreground text-sm rounded-lg shadow-xl border border-border z-50 pointer-events-none group-hover:pointer-events-auto">
        <span class="block font-bold mb-1">{termFromSlot}</span>
        <span class="block mb-2 text-muted-foreground leading-relaxed">{description}</span>
        {
          url && url.length > 0 && (
            <a href={url} class="text-accent hover:underline flex items-center gap-1 font-medium">
              詳しく見る →
            </a>
          )
        }
        <span class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-card" />
      </span>
    </span>
  ) : (
    <slot />
  )
}

<style>
  .glossary-word {
    /* カスタムドット下線 */
    background-image: radial-gradient(circle, currentColor 1px, transparent 1px);
    background-position: bottom;
    background-size: 6px 1px;
    background-repeat: repeat-x;
    padding-bottom: 2px;
  }

  /* ツールチップの表示制御 */
  .glossary-tooltip {
    background-color: var(--background);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s, visibility 0.3s, pointer-events 0.3s;
    transition-delay: 0.3s; /* マウスが離れた時の猶予（黄金比への調整） */
  }

  .glossary-word-container:hover .glossary-tooltip {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: none; /* 表示するときは一瞬で */
  }

  /* ツールチップへの架け橋（隙間を埋める） */
  .glossary-word-container::after {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 50%;
    width: 300%; /* 斜め移動を考慮して巨大化 */
    height: 20px;
    transform: translateX(-50%);
    
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.3s, visibility 0.3s;
    transition-delay: 0.3s; /* 猶予期間 */
    background-color: transparent; /* 視認不能な橋 */
    z-index: 40;
  }
  
  .glossary-word-container:hover {
    z-index: 60; /* 新しい吹き出しが古いものの上に重なるように */
  }

  .glossary-word-container:hover::after {
    visibility: visible;
    opacity: 1;
    transition: none; /* 表示するときは一瞬で */
  }

  :global(html[data-theme="dark"]) .glossary-tooltip {
    background-color: var(--background);
    border-color: var(--border);
  }

  :global(html[data-glossary-hidden="true"]) .glossary-word {
    background-image: none !important;
  }
  
  :global(html[data-glossary-hidden="true"]) .glossary-tooltip,
  :global(html[data-glossary-hidden="true"]) .glossary-word-container::after {
    display: none !important;
  }

  :global(html[data-glossary-hidden="true"]) .glossary-word-container {
    cursor: default !important;
  }
</style>
